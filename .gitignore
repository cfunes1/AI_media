# Ignore files generated by the IDE
.idea/
.vscode/

# Ignore compiled binaries
*.exe
*.dll
*.so
*.dylib

# # Ignore media files
# *.wav
# *.mp3
# *.mp4
# *.webm

# Ignore build output directories
/bin/
/build/
/out/

# Python virtual environment + caches (the 72k-file flood that tripped VS Code)
env/
.venv/
__pycache__/
*.py[cod]
.pytest_cache/

# Gradio app cache
.gradio/
